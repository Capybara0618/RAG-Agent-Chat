            actor_role=payload.actor_role,
            reason=payload.reason,
            status="completed",
            owner_role=project.current_owner_role,
        ).ended_at = datetime.utcnow()
        self._record_manual_decision(
            db,
            project=project,
            subject_type="project",
            subject_id=project.id,
